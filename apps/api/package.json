{
  "name": "@preflight/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --packages=external --alias:@preflight/shared=../../packages/shared/src/index.ts --alias:@preflight/engine=../../packages/preflight-engine/src/index.ts --platform=node --format=esm --target=node22 --outfile=dist/index.js --sourcemap",
    "dev": "tsx watch src/index.ts",
    "start": "node --enable-source-maps dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@celo/attribution-tags": "0.3.0",
    "@mento-protocol/mento-sdk": "3.3.0-beta.2",
    "@preflight/engine": "workspace:*",
    "@preflight/shared": "workspace:*",
    "@x402/core": "2.18.0",
    "@x402/evm": "2.18.0",
    "@x402/express": "2.18.0",
    "express": "5.2.1",
    "viem": "2.55.2"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "26.1.1",
    "@types/supertest": "7.2.1",
    "esbuild": "0.28.1",
    "supertest": "7.2.2",
    "tsx": "4.23.1"
  }
}
