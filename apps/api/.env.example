PORT=3001
CELO_RPC_URL=https://forno.celo.org
CELO_SEPOLIA_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
DATA_DIR=.data

# Exact organizer-assigned ERC-8021 code. Without it, reports truthfully mark Track 1 credit as unproven.
REQUIRED_ATTRIBUTION_TAG=

# Hosted paid mode stays disabled unless all three values are present and the facilitator supports Celo.
X402_FACILITATOR_URL=
X402_PAY_TO=
X402_PRICE=$0.01

# Use a dedicated unfunded key locally. Production must inject a dedicated report signer.
REPORT_SIGNER_PRIVATE_KEY=
